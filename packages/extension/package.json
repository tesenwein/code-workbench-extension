{
  "name": "code-workbench",
  "displayName": "Code Workbench",
  "description": "Saved Claude sessions, task management, and git worktree tree management.",
  "version": "0.1.36",
  "publisher": "tesenwein",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tesenwein/code-workbench-monorepo.git",
    "directory": "packages/extension"
  },
  "activationEvents": [
    "workspaceContains:.git",
    "workspaceContains:.code-workbench"
  ],
  "main": "./dist/extension.js",
  "enabledApiProposals": [
    "terminalDataWriteEvent"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeWorkbench",
          "title": "Code Workbench",
          "icon": "media/spark.svg"
        }
      ]
    },
    "views": {
      "codeWorkbench": [
        {
          "id": "codeWorkbench.brand",
          "name": "Workbench",
          "type": "webview",
          "initialSize": 2,
          "visibility": "visible"
        },
        {
          "id": "codeWorkbench.worktrees",
          "name": "Worktrees",
          "type": "webview",
          "initialSize": 3,
          "visibility": "collapsed"
        },
        {
          "id": "codeWorkbench.tasks",
          "name": "Tasks",
          "type": "webview",
          "initialSize": 10,
          "visibility": "visible"
        },
        {
          "id": "codeWorkbench.sessions",
          "name": "Chats & Terminals",
          "type": "webview",
          "initialSize": 8,
          "visibility": "visible"
        },
        {
          "id": "codeWorkbench.codeHealth",
          "name": "Tools",
          "initialSize": 3,
          "visibility": "visible"
        },
        {
          "id": "codeWorkbench.arch",
          "name": "Architecture",
          "type": "webview",
          "initialSize": 3,
          "visibility": "collapsed"
        }
      ]
    },
    "commands": [
      {
        "command": "codeWorkbench.init",
        "category": "Code Workbench",
        "title": "Initialize in This Repo",
        "icon": "$(rocket)"
      },
      {
        "command": "codeWorkbench.applyFonts",
        "category": "Code Workbench",
        "title": "Apply Workbench Fonts"
      },
      {
        "command": "codeWorkbench.installWorkbenchSkills",
        "category": "Code Workbench",
        "title": "Install Workbench Skills"
      },
      {
        "command": "codeWorkbench.installWorkbenchPermissions",
        "category": "Code Workbench",
        "title": "Add Workbench MCP Permissions"
      },
      {
        "command": "codeWorkbench.applyMinimalLayout",
        "category": "Code Workbench",
        "title": "Apply Minimal Layout"
      },
      {
        "command": "codeWorkbench.openGlobalPrefs",
        "category": "Code Workbench",
        "title": "Open Settings…",
        "icon": "$(settings-gear)"
      },
      {
        "command": "codeWorkbench.checkForUpdates",
        "category": "Code Workbench",
        "title": "Check for Updates…",
        "icon": "$(cloud-download)"
      },
      {
        "command": "codeWorkbench.toggleOpenOnStartup",
        "category": "Code Workbench",
        "title": "Toggle Open on Startup"
      },
      {
        "command": "codeWorkbench.pinSidebar",
        "category": "Code Workbench",
        "title": "Pin Sidebar (Auto-Open)",
        "icon": "$(pin)"
      },
      {
        "command": "codeWorkbench.unpinSidebar",
        "category": "Code Workbench",
        "title": "Unpin Sidebar",
        "icon": "$(pinned)"
      },
      {
        "command": "codeWorkbench.worktrees.refresh",
        "category": "Code Workbench",
        "title": "Refresh Worktrees",
        "icon": "$(refresh)"
      },
      {
        "command": "codeWorkbench.worktrees.add",
        "category": "Code Workbench",
        "title": "Add Worktree…",
        "icon": "$(add)"
      },
      {
        "command": "codeWorkbench.worktrees.addWithTask",
        "category": "Code Workbench",
        "title": "Add Worktree with Task…",
        "icon": "$(add)"
      },
      {
        "command": "codeWorkbench.worktrees.addFromIssue",
        "category": "Code Workbench",
        "title": "Add Worktree from GitHub Issue…",
        "icon": "$(github)"
      },
      {
        "command": "codeWorkbench.worktrees.remove",
        "category": "Code Workbench",
        "title": "Remove Worktree",
        "icon": "$(trash)"
      },
      {
        "command": "codeWorkbench.worktrees.cleanupMerged",
        "category": "Code Workbench",
        "title": "Clean Up Merged Worktrees…",
        "icon": "$(clear-all)"
      },
      {
        "command": "codeWorkbench.worktrees.open",
        "category": "Code Workbench",
        "title": "Open Worktree in New Window",
        "icon": "$(link-external)"
      },
      {
        "command": "codeWorkbench.worktrees.switch",
        "category": "Code Workbench",
        "title": "Switch Worktree…",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "codeWorkbench.worktrees.spawnHere",
        "category": "Code Workbench",
        "title": "New Session in This Worktree…",
        "icon": "$(terminal)"
      },
      {
        "command": "codeWorkbench.worktrees.configure",
        "category": "Code Workbench",
        "title": "Configure Claude (Model & Effort)…",
        "icon": "$(settings-gear)"
      },
      {
        "command": "codeWorkbench.worktrees.openPR",
        "category": "Code Workbench",
        "title": "Open Pull Request",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "codeWorkbench.tasks.refresh",
        "category": "Code Workbench",
        "title": "Refresh Tasks",
        "icon": "$(refresh)"
      },
      {
        "command": "codeWorkbench.deadCode.scan",
        "category": "Code Workbench",
        "title": "Dead Code: Scan & Open Page",
        "icon": "$(trash)"
      },
      {
        "command": "codeWorkbench.duplicates.scan",
        "category": "Code Workbench",
        "title": "Duplicate Code: Scan & Open Page",
        "icon": "$(copy)"
      },
      {
        "command": "codeWorkbench.typeEscapes.scan",
        "category": "Code Workbench",
        "title": "Type Safety: Scan & Open Page",
        "icon": "$(shield)"
      },
      {
        "command": "codeWorkbench.searchCode",
        "category": "Code Workbench",
        "title": "Search Code…",
        "icon": "$(search)"
      },
      {
        "command": "codeWorkbench.codeReview.start",
        "category": "Code Workbench",
        "title": "Code Review: Review Current Changes",
        "icon": "$(checklist)"
      },
      {
        "command": "codeWorkbench.plan.start",
        "category": "Code Workbench",
        "title": "Plan Feature",
        "icon": "$(compass)"
      },
      {
        "command": "codeWorkbench.themeTokens",
        "category": "Code Workbench",
        "title": "Theme Tokens",
        "icon": "$(symbol-color)"
      },
      {
        "command": "codeWorkbench.worktrees.editNote",
        "category": "Code Workbench",
        "title": "Edit Handoff Note…",
        "icon": "$(note)"
      },
      {
        "command": "codeWorkbench.arch.refresh",
        "category": "Code Workbench",
        "title": "Refresh Architecture",
        "icon": "$(refresh)"
      },
      {
        "command": "codeWorkbench.arch.openAsPage",
        "category": "Code Workbench",
        "title": "Open Architecture as Page",
        "icon": "$(link-external)"
      },
      {
        "command": "codeWorkbench.tasks.create",
        "category": "Code Workbench",
        "title": "New Task…",
        "icon": "$(add)"
      },
      {
        "command": "codeWorkbench.tasks.filter",
        "category": "Code Workbench",
        "title": "Filter Tasks…",
        "icon": "$(filter)"
      },
      {
        "command": "codeWorkbench.tasks.clearFilter",
        "category": "Code Workbench",
        "title": "Clear Task Filter",
        "icon": "$(filter-filled)"
      },
      {
        "command": "codeWorkbench.sessions.new",
        "category": "Code Workbench",
        "title": "New Claude Session",
        "icon": "$(add)"
      },
      {
        "command": "codeWorkbench.sessions.newYolo",
        "category": "Code Workbench",
        "title": "New Claude Session (Yolo)"
      },
      {
        "command": "codeWorkbench.sessions.newShell",
        "category": "Code Workbench",
        "title": "New Shell Session"
      },
      {
        "command": "codeWorkbench.sessions.newPlan",
        "category": "Code Workbench",
        "title": "New Claude Session (Plan Mode)",
        "icon": "$(checklist)"
      },
      {
        "command": "codeWorkbench.sessions.newFromEditor",
        "category": "Code Workbench",
        "title": "New Session…",
        "icon": "media/spark-blue.svg"
      },
      {
        "command": "codeWorkbench.sessions.open",
        "category": "Code Workbench",
        "title": "Open Session"
      },
      {
        "command": "codeWorkbench.sessions.rename",
        "category": "Code Workbench",
        "title": "Rename Session"
      },
      {
        "command": "codeWorkbench.sessions.setIcon",
        "category": "Code Workbench",
        "title": "Set Session Tab Icon…"
      },
      {
        "command": "codeWorkbench.sessions.close",
        "category": "Code Workbench",
        "title": "Close Session",
        "icon": "$(trash)"
      },
      {
        "command": "codeWorkbench.sessions.closeInactive",
        "category": "Code Workbench",
        "title": "Remove Inactive Sessions",
        "icon": "$(clear-all)"
      },
      {
        "command": "codeWorkbench.tasks.openAsPage",
        "category": "Code Workbench",
        "title": "Open Task Board as Page",
        "icon": "$(link-external)"
      },
      {
        "command": "codeWorkbench.tasks.openPhaseBoard",
        "category": "Code Workbench",
        "title": "Open Phase Board",
        "icon": "$(run-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codeWorkbench.init",
          "when": "view == codeWorkbench.worktrees",
          "group": "2_manage@3"
        },
        {
          "command": "codeWorkbench.checkForUpdates",
          "when": "view == codeWorkbench.brand && !codeWorkbench.updateAvailable",
          "group": "navigation@0"
        },
        {
          "command": "codeWorkbench.checkForUpdates",
          "when": "view == codeWorkbench.brand && codeWorkbench.updateAvailable",
          "group": "navigation@0",
          "icon": "$(arrow-circle-up)"
        },
        {
          "command": "codeWorkbench.openGlobalPrefs",
          "when": "view == codeWorkbench.brand",
          "group": "navigation@1"
        },
        {
          "command": "codeWorkbench.sessions.newFromEditor",
          "when": "view == codeWorkbench.brand",
          "group": "navigation@2"
        },
        {
          "command": "codeWorkbench.pinSidebar",
          "when": "view == codeWorkbench.worktrees && !codeWorkbench.sidebarPinned",
          "group": "2_manage@2"
        },
        {
          "command": "codeWorkbench.unpinSidebar",
          "when": "view == codeWorkbench.worktrees && codeWorkbench.sidebarPinned",
          "group": "2_manage@2"
        },
        {
          "command": "codeWorkbench.worktrees.addWithTask",
          "when": "view == codeWorkbench.worktrees",
          "group": "navigation@1"
        },
        {
          "command": "codeWorkbench.worktrees.switch",
          "when": "view == codeWorkbench.worktrees",
          "group": "navigation@2"
        },
        {
          "command": "codeWorkbench.worktrees.refresh",
          "when": "view == codeWorkbench.worktrees",
          "group": "navigation@3"
        },
        {
          "command": "codeWorkbench.worktrees.add",
          "when": "view == codeWorkbench.worktrees",
          "group": "1_add@1"
        },
        {
          "command": "codeWorkbench.worktrees.addFromIssue",
          "when": "view == codeWorkbench.worktrees",
          "group": "1_add@2"
        },
        {
          "command": "codeWorkbench.worktrees.cleanupMerged",
          "when": "view == codeWorkbench.worktrees",
          "group": "2_manage@1"
        },
        {
          "command": "codeWorkbench.worktrees.switch",
          "when": "view == codeWorkbench.tasks",
          "group": "navigation@0"
        },
        {
          "command": "codeWorkbench.tasks.refresh",
          "when": "view == codeWorkbench.tasks",
          "group": "navigation"
        },
        {
          "command": "codeWorkbench.tasks.filter",
          "when": "view == codeWorkbench.tasks && !codeWorkbench.tasks.filtered",
          "group": "navigation@2"
        },
        {
          "command": "codeWorkbench.tasks.clearFilter",
          "when": "view == codeWorkbench.tasks && codeWorkbench.tasks.filtered",
          "group": "navigation@2"
        },
        {
          "command": "codeWorkbench.tasks.create",
          "when": "view == codeWorkbench.tasks",
          "group": "navigation"
        },
        {
          "command": "codeWorkbench.arch.refresh",
          "when": "view == codeWorkbench.arch",
          "group": "navigation"
        },
        {
          "command": "codeWorkbench.arch.openAsPage",
          "when": "view == codeWorkbench.arch",
          "group": "navigation@1"
        },
        {
          "command": "codeWorkbench.sessions.closeInactive",
          "when": "view == codeWorkbench.sessions",
          "group": "navigation@0"
        },
        {
          "command": "codeWorkbench.sessions.newFromEditor",
          "when": "view == codeWorkbench.sessions",
          "group": "navigation@1"
        },
        {
          "command": "codeWorkbench.tasks.openAsPage",
          "when": "view == codeWorkbench.tasks",
          "group": "navigation@1"
        },
        {
          "command": "codeWorkbench.tasks.openPhaseBoard",
          "when": "view == codeWorkbench.tasks",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "Code Workbench",
      "properties": {
        "codeWorkbench.claudeCommand": {
          "type": "string",
          "default": "claude",
          "description": "Command to launch Claude Code in saved sessions."
        },
        "codeWorkbench.claudeYoloArgs": {
          "type": "string",
          "default": "--dangerously-skip-permissions",
          "description": "Extra args for the 'yolo' Claude session profile."
        },
        "codeWorkbench.sessionPanel": {
          "type": "string",
          "enum": [
            "editor",
            "panel",
            "bottom-group"
          ],
          "default": "panel",
          "enumDescriptions": [
            "Open each session as a dedicated terminal tab in the editor area.",
            "Open sessions in the bottom terminal panel alongside other terminals.",
            "Open sessions in a reserved, locked editor group below the main editor (created on first use)."
          ],
          "description": "Where to open Claude/shell sessions."
        },
        "codeWorkbench.mcp.tasks.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Inject the bundled tasks MCP server into Claude sessions so Claude can read/write workspace tasks."
        },
        "codeWorkbench.mcp.notifications.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Inject the bundled notifications MCP server so Claude can surface 'done', 'needs input', and progress events as VS Code notifications, and rename session tabs."
        },
        "codeWorkbench.mcp.arch.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Inject the bundled architecture wiki MCP server into Claude sessions so Claude can read/write component cards."
        },
        "codeWorkbench.mcp.typeSafety.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Inject the bundled type-safety MCP server (cw-type-safety) so Claude can read type-escape findings — as-casts, explicit any, non-null assertions, and @ts-ignore directives."
        },
        "codeWorkbench.sessionProfiles": {
          "type": "array",
          "default": [],
          "description": "Custom session profiles shown alongside Claude/Shell in the session picker. Each profile launches an arbitrary command in a worktree-rooted terminal.",
          "items": {
            "type": "object",
            "required": [
              "label",
              "command"
            ],
            "properties": {
              "label": {
                "type": "string",
                "description": "Display name in the session picker."
              },
              "command": {
                "type": "string",
                "description": "Executable to launch."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Arguments passed to the command."
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "default": {},
                "description": "Environment variables for the session terminal."
              },
              "icon": {
                "type": "string",
                "description": "Optional codicon id for the session tab (e.g. 'beaker')."
              }
            }
          }
        },
        "codeWorkbench.restoreSessionsOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Reopen the saved session terminals for the active worktree when the workspace opens."
        },
        "codeWorkbench.autoCheckForUpdates": {
          "type": "boolean",
          "default": true,
          "description": "Check GitHub Releases once a day for a newer Code Workbench release and offer to install it."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "dist": "npm run build && node -e \"require('fs').mkdirSync('../../release/extension',{recursive:true})\" && npx @vscode/vsce package --no-dependencies --out ../../release/extension/",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "@code-workbench/git-utils": "workspace:*",
    "@code-workbench/mcp-core": "workspace:*",
    "@code-workbench/ui": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "globals": "latest",
    "typescript": "^5.9.3",
    "typescript-eslint": "latest"
  }
}
