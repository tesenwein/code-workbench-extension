{
  "window.title": "✳ code-workbench-extension · develop — Code Workbench${separator}${activeEditorShort}",
  "workbench.activityBar.location": "top",
  "workbench.layoutControl.enabled": true,
  "window.commandCenter": false,
  "breadcrumbs.enabled": false,
  "editor.minimap.enabled": false,
  "editor.glyphMargin": false,
  "workbench.editor.showTabs": "multiple",
  "workbench.sideBar.location": "left",
  "workbench.statusBar.visible": true,
  "editor.lineNumbers": "on",
  "problems.visibility": false,
  "terminal.integrated.tabs.hideCondition": "never",
  "workbench.panel.defaultLocation": "bottom",
  "workbench.tree.indent": 12,
  "workbench.editor.editorActionsLocation": "hidden",
  "workbench.colorCustomizations": {
    "statusBar.background": "#5e4c3f",
    "statusBar.foreground": "#e8ddc8",
    "statusBar.border": "#5e4c3f",
    "statusBar.noFolderBackground": "#5e4c3f",
    "statusBar.debuggingBackground": "#5e4c3f",
    "statusBarItem.remoteBackground": "#5e4c3f",
    "statusBarItem.remoteForeground": "#e8ddc8"
  }
}
