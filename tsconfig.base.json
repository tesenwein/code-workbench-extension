{
  "$schema": "https://json.schemastore.org/tsconfig",
  "//": "Shared TypeScript compiler options for every workspace package. Packages extend this and override only what they need (lib, jsx, module, outDir, paths).",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noFallthroughCasesInSwitch": true,
    "useDefineForClassFields": true
  }
}
